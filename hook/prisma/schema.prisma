generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
//User
//Zap
//Trigger
//AvaliableTrigger
//Actions
//AvaliableAction
//ZapRun
//ZapRunOutbox

model User {
	id		Int @id @default(autoincrement())
	username	String @unique
	password	String
	zap			Zap[]
}

model Zap {
	id			Int @id @default(uuid())
	triggerId	String
	userId		String
	user		User @relation(fields: [userId], references: [id])
	trigger		Trigger?
	action 		Action[]
	zapRun		zapRun[]
}

model Trigger {
	id			Int @id @default(uuid())
	zapId		String @unique
	triggerId	String
	type		AvailableTrigger @relation(fields: [triggerId], references: [id])
	zap 		Zap @relation(fields: [zapId], references: [id])
	action		Action[]
}

model AvailableTrigger {
	id 		Int @id @default(uuid())
	name	String
	image	String
	trigger Trigger[]
}

model Action {
	id		Int @id @default(uuid())
	triggerId	String
	actionId	String
	metadata	Json @default("{}")
	trigger		Trigger @relation(fields: [triggerId], references: [id])
	type		AvailableAction @relation(fields: [actionId	], references: [id])
}

model AvailableAction {
	id		Int @id @default(uuid())
	name 	String
	image	String
	action	Action[]
}

model zapRun {
	id		Int @id @default(uuid())
	zapId   String 
	metadata Json
	zap 		Zap @relation(fields: [zapId], references: [id])
}

model zapRunOutbox {
	id 		Int @id @default(uuid())
	zapId	String @unique
	zapRun  zapRun @relation(fields: [zapId], references: [id])
}